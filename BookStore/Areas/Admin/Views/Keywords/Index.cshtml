@model IEnumerable<BookStore.Models.Keyword>

@{
    ViewData["Title"] = "مدیریت کلمات کلیدی";
}

<div class="page-header">
    <h2>🔑 مدیریت کلمات کلیدی</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> کلمه کلیدی جدید
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>کلمه کلیدی</th>
                        <th>تعداد کتاب‌ها</th>
                        <th class="text-center">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var keyword in Model)
                    {
                        <tr>
                            <td class="fw-bold">@keyword.Word</td>
                            <td><span class="badge bg-info">@(keyword.BookKeywords?.Count ?? 0)</span></td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    <a asp-action="Edit" asp-route-id="@keyword.Id" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@keyword.Id" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
