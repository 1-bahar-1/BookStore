@model BookStore.Models.Author

@{
    ViewData["Title"] = "حذف نویسنده";
}

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-body">
                <h1 class="h4 mb-4 text-danger">حذف نویسنده</h1>

                <p>آیا از حذف نویسنده <strong>@Model.FullName</strong> مطمئن هستید؟</p>
                <p class="text-muted small">تمامی ارتباطات این نویسنده با کتاب‌ها نیز حذف خواهد شد.</p>

                <form asp-action="Delete" asp-controller="Authors" asp-area="Admin" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Id" />

                    <button type="submit" class="btn btn-danger">بله، حذف کن</button>
                    <a asp-action="Index" class="btn btn-secondary">خیر، بازگشت</a>
                </form>
            </div>
        </div>
    </div>
</div>
