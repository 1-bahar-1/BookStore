@model BookStore.Areas.Admin.Models.BookFormViewModel

@{
    ViewData["Title"] = Model.Id == 0 ? "ایجاد کتاب جدید" : "ویرایش کتاب";
}

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h1 class="h4 mb-4">@ViewData["Title"]</h1>

                <form asp-action="@(Model.Id == 0 ? "Create" : "Edit")" 
                      asp-controller="Books" 
                      asp-area="Admin" 
                      method="post" 
                      enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <input type="hidden" asp-for="Id" />

                    <div class="form-group mb-3">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Slug" class="form-label"></label>
                        <input asp-for="Slug" class="form-control" />
                        <span asp-validation-for="Slug" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="ISBN" class="form-label"></label>
                                <input asp-for="ISBN" class="form-control" placeholder="مثال: 978-964-12345-1-1" />
                                <span asp-validation-for="ISBN" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="PublishedYear" class="form-label"></label>
                                <input asp-for="PublishedYear" class="form-control" type="number" min="1000" max="2100" />
                                <span asp-validation-for="PublishedYear" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="IsFree" class="form-label"></label>
                        <select asp-for="IsFree" class="form-select">
                            <option value="true">رایگان</option>
                            <option value="false">پولی</option>
                        </select>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.CoverImagePath))
                    {
                        <div class="form-group mb-3">
                            <label class="form-label">کاور فعلی</label>
                            <div>
                                <img src="@Model.CoverImagePath" alt="کاور" style="max-height: 150px; border-radius: 8px; border: 1px solid #dee2e6;" />
                            </div>
                        </div>
                    }

                    <div class="form-group mb-3">
                        <label class="form-label">بارگذاری کاور @(string.IsNullOrEmpty(Model.CoverImagePath) ? "" : "(اختیاری - برای جایگزینی)")</label>
                        <input type="file" name="coverImage" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                        <span asp-validation-for="CoverImagePath" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="PageCount" class="form-label"></label>
                                <input asp-for="PageCount" class="form-control" type="number" min="1" />
                                <span asp-validation-for="PageCount" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="CategoryId" class="form-label"></label>
                                <select asp-for="CategoryId" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.Categories, "Id", "Name"))">
                                    <option value="">انتخاب کنید</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.FilePath))
                    {
                        <div class="form-group mb-3">
                            <label class="form-label">فایل فعلی</label>
                            <div class="input-group">
                                <input value="@Model.FilePath" class="form-control" readonly />
                                <a href="@Model.FilePath" target="_blank" class="btn btn-outline-secondary">مشاهده</a>
                            </div>
                        </div>
                    }

                    <div class="form-group mb-3">
                        <label class="form-label">بارگذاری PDF @(string.IsNullOrEmpty(Model.FilePath) ? "" : "(اختیاری - برای جایگزینی فایل فعلی)")</label>
                        <input type="file" name="pdfFile" class="form-control" accept=".pdf" />
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">نویسنده‌ها</label>
                        <div class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var author in Model.Authors)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="AuthorIds" value="@author.AuthorId" @(author.IsSelected ? "checked" : "") />
                                    <label class="form-check-label">@author.FullName</label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">کلمات کلیدی</label>
                        <div class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var keyword in Model.Keywords)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="KeywordIds" value="@keyword.KeywordId" @(keyword.IsSelected ? "checked" : "") />
                                    <label class="form-check-label">@keyword.Word</label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">کتاب‌های مرتبط</label>
                        <div class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var relatedBook in Model.RelatedBooks)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="RelatedBookIds" value="@relatedBook.BookId" @(relatedBook.IsSelected ? "checked" : "") />
                                    <label class="form-check-label">@relatedBook.Title</label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">@ViewData["Title"]</button>
                        <a asp-action="Index" class="btn btn-secondary">لغو</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
