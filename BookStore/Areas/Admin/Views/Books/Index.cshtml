@model IEnumerable<BookStore.Models.Book>

@{
    ViewData["Title"] = "لیست کتاب‌ها";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>مدیریت کتاب‌ها</h2>
    <a asp-action="Create" class="btn btn-success">➕ افزودن کتاب جدید</a>
</div>

<table class="table table-bordered table-striped bg-white shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>عنوان</th>
            <th>دسته‌بندی</th>
            <th>ISBN</th>
            <th>نوع</th>
            <th>تعداد صفحات</th>
            <th>کاور</th>
            <th>فایل</th>
            <th>عملیات</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Category?.Name</td>
                <td>@item.ISBN</td>
                <td>
                    @if (item.IsFree)
                    {
                        <span class="badge bg-success">رایگان</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">پولی</span>
                    }
                </td>
                <td>@item.PageCount</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.CoverImagePath))
                    {
                        <img src="@item.CoverImagePath" alt="کاور" style="height: 40px; border-radius: 4px;" />
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </td>
                <td>
                    @if (!string.IsNullOrEmpty(item.FilePath))
                    {
                        <span class="badge bg-info">دارد</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">ندارد</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">ویرایش</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">حذف</a>
                </td>
            </tr>
        }
    </tbody>
</table>
