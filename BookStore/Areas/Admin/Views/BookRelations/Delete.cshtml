@model BookStore.Models.BookRelation

@{
    ViewData["Title"] = "حذف رابطه کتاب";
}

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-body">
                <h1 class="h4 mb-4 text-danger">حذف رابطه کتاب</h1>

                <p>آیا از حذف رابطه بین <strong>@Model.Book.Title</strong> و <strong>@Model.RelatedBook.Title</strong> مطمئن هستید؟</p>

                <form asp-action="Delete" asp-controller="BookRelations" asp-area="Admin" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Id" />

                    <button type="submit" class="btn btn-danger">بله، حذف کن</button>
                    <a asp-action="Index" class="btn btn-secondary">خیر، بازگشت</a>
                </form>
            </div>
        </div>
    </div>
</div>
