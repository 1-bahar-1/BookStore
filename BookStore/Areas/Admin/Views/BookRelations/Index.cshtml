@model IEnumerable<BookStore.Models.BookRelation>

@{
    ViewData["Title"] = "مدیریت کتاب‌های مرتبط";
}

<div class="page-header">
    <h2>🔗 مدیریت کتاب‌های مرتبط</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> افزودن رابطه
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>کتاب اول</th>
                        <th>کتاب مرتبط</th>
                        <th class="text-center">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rel in Model)
                    {
                        <tr>
                            <td class="fw-bold">@rel.Book?.Title</td>
                            <td>@rel.RelatedBook?.Title</td>
                            <td class="text-center">
                                <a asp-action="Delete" asp-route-id="@rel.Id" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
