@model BookStore.Models.BookRelation

@{
    ViewData["Title"] = "افزودن رابطه کتاب";
}

<div class="page-header">
    <h2>افزودن رابطه کتاب</h2>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" asp-controller="BookRelations" asp-area="Admin" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="BookId" class="form-label fw-bold"></label>
                        <select asp-for="BookId" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(ViewBag.Books, "Id", "Title"))">
                            <option value="">انتخاب کنید</option>
                        </select>
                        <span asp-validation-for="BookId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="RelatedBookId" class="form-label fw-bold"></label>
                        <select asp-for="RelatedBookId" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(ViewBag.Books, "Id", "Title"))">
                            <option value="">انتخاب کنید</option>
                        </select>
                        <span asp-validation-for="RelatedBookId" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> افزودن
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> لغو
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
