@model BookStore.Models.BookRelation

@{
    ViewData["Title"] = "افزودن رابطه جدید";
}

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h1 class="h4 mb-4">افزودن رابطه کتاب</h1>

                <form asp-action="Create" asp-controller="BookRelations" asp-area="Admin" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group mb-3">
                        <label asp-for="BookId" class="form-label"></label>
                        <select asp-for="BookId" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(ViewBag.Books, "Id", "Title"))">
                            <option value="">انتخاب کنید</option>
                        </select>
                        <span asp-validation-for="BookId" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="RelatedBookId" class="form-label"></label>
                        <select asp-for="RelatedBookId" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(ViewBag.Books, "Id", "Title"))">
                            <option value="">انتخاب کنید</option>
                        </select>
                        <span asp-validation-for="RelatedBookId" class="text-danger"></span>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">افزودن</button>
                        <a asp-action="Index" class="btn btn-secondary">لغو</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
