<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        :root {
            --primary: #2c3e50;
            --secondary: #3498db;
            --accent: #e74c3c;
            --light: #ecf0f1;
            --dark: #2c3e50;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #e4e9f0 100%);
            min-height: 100vh;
        }

        .navbar {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            box-shadow: 0 2px 20px rgba(0,0,0,0.05);
        }

        .navbar-brand {
            font-weight: 700;
            color: var(--primary) !important;
            font-size: 1.4rem;
            letter-spacing: -0.5px;
        }

        .navbar-brand i {
            color: var(--secondary);
        }

        .nav-link {
            font-weight: 500;
            color: #555 !important;
            transition: all 0.3s;
            border-radius: 8px;
            padding: 8px 16px !important;
        }

        .nav-link:hover, .nav-link.active {
            color: var(--secondary) !important;
            background: rgba(52, 152, 219, 0.08);
        }

        .btn-primary {
            background: var(--secondary);
            border-color: var(--secondary);
            border-radius: 10px;
            padding: 10px 24px;
            font-weight: 500;
            transition: all 0.3s;
        }

        .btn-primary:hover {
            background: #2980b9;
            border-color: #2980b9;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(52, 152, 219, 0.3);
        }

        .btn-outline-primary {
            border-radius: 10px;
            padding: 10px 24px;
            font-weight: 500;
            border-width: 2px;
        }

        .card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.06);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            background: white;
            overflow: hidden;
        }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.12);
        }

        .card-body {
            padding: 1.5rem;
        }

        .book-card {
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .book-card .card-body {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .book-card .card-title {
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 1rem;
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .book-card .card-text {
            flex: 1;
            color: #666;
            font-size: 0.9rem;
        }

        .badge {
            font-weight: 500;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
        }

        .badge-free {
            background: linear-gradient(135deg, #27ae60, #2ecc71);
            color: white;
        }

        .badge-paid {
            background: linear-gradient(135deg, #f39c12, #e67e22);
            color: white;
        }

        .hero-section {
            background: linear-gradient(135deg, var(--primary) 0%, #34495e 100%);
            color: white;
            padding: 4rem 0;
            border-radius: 20px;
            margin-bottom: 3rem;
            position: relative;
            overflow: hidden;
        }

        .hero-section::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 600px;
            height: 600px;
            background: rgba(255,255,255,0.03);
            border-radius: 50%;
        }

        .hero-section h1 {
            font-weight: 800;
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }

        .hero-section p {
            font-size: 1.1rem;
            opacity: 0.9;
        }

        .search-box {
            max-width: 600px;
            margin: 0 auto;
            position: relative;
        }

        .search-box input {
            border-radius: 50px;
            border: 2px solid rgba(255,255,255,0.2);
            background: rgba(255,255,255,0.1);
            color: white;
            padding: 15px 25px;
            font-size: 1rem;
        }

        .search-box input::placeholder {
            color: rgba(255,255,255,0.6);
        }

        .search-box input:focus {
            background: rgba(255,255,255,0.2);
            border-color: rgba(255,255,255,0.4);
            color: white;
            box-shadow: none;
        }

        .footer {
            background: var(--primary);
            color: white;
            padding: 3rem 0 2rem;
            margin-top: 5rem;
        }

        .footer h5 {
            font-weight: 700;
            margin-bottom: 1.5rem;
        }

        .footer a {
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer a:hover {
            color: white;
        }

        .btn-download {
            background: linear-gradient(135deg, #27ae60, #2ecc71);
            border: none;
            color: white;
            font-weight: 600;
            border-radius: 12px;
            padding: 12px 28px;
            transition: all 0.3s;
        }

        .btn-download:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(39, 174, 96, 0.4);
            color: white;
        }

        .author-chip {
            background: white;
            border: 1px solid #e0e0e0;
            border-radius: 50px;
            padding: 8px 16px;
            margin: 4px;
            display: inline-block;
            transition: all 0.3s;
            text-decoration: none;
            color: var(--dark);
            font-size: 0.9rem;
        }

        .author-chip:hover {
            background: var(--secondary);
            color: white;
            border-color: var(--secondary);
            transform: translateY(-2px);
        }

        .keyword-chip {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border-radius: 50px;
            padding: 6px 14px;
            margin: 4px;
            display: inline-block;
            text-decoration: none;
            font-size: 0.85rem;
            transition: all 0.3s;
        }

        .keyword-chip:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
            color: white;
        }

        .related-book-card {
            border-radius: 12px;
            transition: all 0.3s;
        }

        .related-book-card:hover {
            transform: scale(1.03);
        }

        .pagination .page-link {
            color: var(--secondary);
            border: none;
            background: white;
            margin: 0 4px;
            border-radius: 8px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }

        .pagination .page-item.active .page-link {
            background: var(--secondary);
            color: white;
        }

        .pagination .page-link:hover {
            background: var(--light);
        }

        .section-title {
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 1.5rem;
            position: relative;
            padding-bottom: 10px;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            right: 0;
            width: 60px;
            height: 3px;
            background: var(--secondary);
            border-radius: 2px;
        }

        .filter-card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.04);
            border: 1px solid rgba(0,0,0,0.04);
        }

        select.form-select {
            border-radius: 10px;
            border: 1px solid #e0e0e0;
            padding: 10px 15px;
        }

        .alert {
            border-radius: 12px;
            border: none;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-book-half"></i> BookStore
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door"></i> خانه
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Book" asp-action="Index">
                            <i class="bi bi-book"></i> کتاب‌ها
                        </a>
                    </li>
                </ul>

                <form class="d-flex me-lg-3 mb-3 mb-lg-0" method="get" asp-controller="Book" asp-action="Index" style="max-width: 350px;">
                    <div class="input-group">
                        <input class="form-control" name="q" value="@Context.Request.Query["q"]" placeholder="جستجوی کتاب..." />
                        <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
                    </div>
                </form>

                <ul class="navbar-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle fs-5 me-1"></i>
                                <span>@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                @if (User.IsInRole("Admin"))
                                {
                                    <li>
                                        <a class="dropdown-item text-primary" asp-area="Admin" asp-controller="Books" asp-action="Index">
                                            <i class="bi bi-gear"></i> پنل مدیریت
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right"></i> خروج از حساب
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-primary me-2" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> ورود
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus"></i> ثبت نام
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container my-5">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5><i class="bi bi-book-half"></i> BookStore</h5>
                    <p class="text-white-50">فروشگاه تخصصی کتاب دیجیتال. بهترین منابع را با ما تجربه کنید.</p>
                </div>
                <div class="col-md-4">
                    <h5>دسترسی سریع</h5>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="Index">صفحه اصلی</a></li>
                        <li><a asp-controller="Book" asp-action="Index">کتاب‌ها</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h5>ارتباط با ما</h5>
                    <div class="d-flex gap-3">
                        <a href="#" class="text-white-50"><i class="bi bi-telegram fs-4"></i></a>
                        <a href="#" class="text-white-50"><i class="bi bi-instagram fs-4"></i></a>
                        <a href="#" class="text-white-50"><i class="bi bi-envelope fs-4"></i></a>
                    </div>
                </div>
            </div>
            <hr class="my-4 border-white-20">
            <p class="text-center text-white-50 mb-0">© 2026 BookStore - فروشگاه تخصصی کتاب دیجیتال</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
