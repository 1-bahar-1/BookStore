<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>

    <!-- Bootstrap RTL -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        body {
            font-family: Tahoma, Arial, sans-serif;
            text-align: right;
        }

        .navbar-brand {
            font-size: 1.5rem;
        }
    </style>
</head>

<body style="background:#f8f9fa;">

    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
            <div class="container">

                <!-- Logo -->
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    📚 BookStore
                </a>

                <!-- Toggle -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div id="nav" class="collapse navbar-collapse">

                    <!-- Menu -->
                    <ul class="navbar-nav me-3">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">خانه</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Books" asp-action="Index">کتاب‌ها</a>
                        </li>
                    </ul>

                    <!-- 🔍 Search (اصلاح شده → BooksController) -->
                    <form class="d-flex me-auto" method="get" asp-controller="Books" asp-action="Index">
                        <input class="form-control me-2"
                               name="q"
                               value="@Context.Request.Query["q"]"
                               placeholder="جستجوی کتاب..."
                               aria-label="Search" />
                        <button class="btn btn-outline-primary" type="submit">جستجو</button>
                    </form>

                    <!-- Auth -->
                    <ul class="navbar-nav ms-3">

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark"
                                   href="#"
                                   id="userDropdown"
                                   role="button"
                                   data-bs-toggle="dropdown">

                                    👋 خوش آمدید، @User.Identity.Name
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end shadow border-0">

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item text-primary"
                                               asp-area="Admin"
                                               asp-controller="Books"
                                               asp-action="Index">
                                                ⚙️ پنل مدیریت
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                    }

                                    <li>
                                        <a class="dropdown-item text-danger"
                                           asp-controller="Account"
                                           asp-action="Logout">
                                            خروج از حساب
                                        </a>
                                    </li>

                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-primary me-2"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    ورود
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-primary"
                                   asp-controller="Account"
                                   asp-action="Register">
                                    ثبت نام
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-5 py-4 bg-white border-top">
        <div class="container text-center text-muted">
            <p class="mb-0">© 2026 BookStore - فروشگاه تخصصی کتاب دیجیتال</p>
            <small>طراحی و توسعه با ASP.NET Core</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>