@model BookStore.Models.Book

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">خانه</a></li>
                    <li class="breadcrumb-item active">@Model.Title</li>
                </ol>
            </nav>

            <div class="card shadow-lg border-0 overflow-hidden">
                <div class="row g-0">
                    <!-- بخش اطلاعات کتاب -->
                    <div class="col-md-8">
                        <div class="card-body p-4">
                            <h1 class="display-6 fw-bold text-primary mb-3">@Model.Title</h1>

                            <div class="d-flex flex-wrap gap-3 mb-4">
                                <span class="badge bg-info text-dark p-2">
                                    📁 دسته‌بندی: @(Model.Category?.Name ?? "بدون دسته‌بندی")
                                </span>
                                <span class="badge bg-light text-dark border p-2">
                                    📄 تعداد صفحات: @Model.PageCount
                                </span>
                            </div>

                            <h5 class="fw-bold mb-3">درباره این کتاب:</h5>
                            @* <p class="text-secondary lh-lg" style="text-align: justify;">
                                @Model.Description
                            </p> *@

                            <hr class="my-4" />

                            <div class="d-grid gap-2 d-md-flex justify-content-md-start">
                                <!-- لینک دانلود امن که به HomeController/Download وصل می‌شود -->
    @foreach (var ba in Model.BookAuthors ?? new List<BookAuthor>())
    {
        <a class="btn btn-sm btn-outline-dark" href="/authors/@ba.Author.Slug">✍️ @ba.Author.FullName</a>
    }

                                <a href="/" class="btn btn-outline-secondary btn-lg">بازگشت به لیست</a>
                            </div>
                        </div>
                    </div>

                    <!-- بخش کناری (می‌توانید اینجا عکس کتاب را بگذارید) -->
                    <div class="col-md-4 bg-light d-flex align-items-center justify-content-center border-start">
                        <div class="text-center p-4">
                            <div class="mb-3">
                                <i class="display-1 bi bi-book text-muted">📚</i>
                            </div>
                            <p class="text-muted small">فرمت فایل: PDF</p>
                            <p class="text-muted small">امنیت تضمین شده ✅</p>
                        </div>
                    </div>
                </div>
            </div>

    @if (User.Identity.IsAuthenticated && !string.IsNullOrEmpty(Model.FilePath))
    {
        <a class="btn btn-success btn-lg px-5 shadow"
           asp-controller="Book"
           asp-action="Download"
           asp-route-id="@Model.Id">
             📥 دانلود رایگان فایل PDF
        </a>
    }

    <div class="mt-3">
        <strong>نویسنده‌ها:</strong>
        @foreach (var ba in Model.BookAuthors ?? new List<BookAuthor>())
        {
            <a class="btn btn-sm btn-outline-dark m-1" href="/authors/@ba.Author.Slug">✍️ @ba.Author.FullName</a>
        }
    </div>

    <div class="mt-3">
        <strong>کلمات کلیدی:</strong>
        @foreach (var bk in Model.BookKeywords ?? new List<BookKeyword>())
        {
            <a class="badge bg-secondary text-decoration-none m-1" href="/keywords/@bk.Keyword.Word">@bk.Keyword.Word</a>
        }
    </div>

    @if (Model.RelatedTo != null && Model.RelatedTo.Any())
    {
        <div class="mt-4">
            <h5 class="fw-bold">📚 کتاب‌های مرتبط</h5>
            <div class="row">
                @foreach (var rel in Model.RelatedTo)
                {
                    var relatedBook = rel.RelatedBook;
                    <div class="col-md-4 mb-3">
                        <div class="card shadow-sm h-100 border-0">
                            <div class="card-body">
                                <h6 class="card-title fw-bold text-primary">@relatedBook.Title</h6>
                                <a class="btn btn-sm btn-primary w-100 mt-2" href="/books/@relatedBook.Slug">مشاهده</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (!User.Identity.IsAuthenticated)
    {
        <div class="alert alert-warning mt-4 shadow-sm" role="alert">
            <strong>توجه:</strong> برای دانلود فایل، ابتدا باید وارد حساب کاربری خود شوید.
        </div>
    }

        </div>
    </div>
</div>
