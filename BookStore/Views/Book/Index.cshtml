@model IEnumerable<BookStore.Models.Book>

@{
    ViewData["Title"] = "فروشگاه کتاب";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">📚 آخرین کتاب‌ها</h2>
    @if (Context.Request.Query.ContainsKey("q"))
    {
        <a href="/" class="btn btn-sm btn-outline-secondary">پاک کردن فیلتر جستجو</a>
    }
</div>

<div class="row">
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <p class="text-muted">هیچ کتابی یافت نشد.</p>
        </div>
    }

    @foreach (var book in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm h-100 border-0">
                <!-- می‌توانید اینجا یک تگ img برای کاور کتاب اضافه کنید -->
                <div class="card-body">
                    <h6 class="card-title fw-bold text-primary">
                        @book.Title
                    </h6>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="badge bg-light text-dark border">
                            @book.Category?.Name
                        </span>
                        <small class="text-muted">📄 @book.PageCount صفحه</small>
                    </div>

                    @* <p class="card-text text-muted small" style="height: 40px; overflow: hidden;">
                        @book.Description
                    </p> *@

                    <a class="btn btn-sm btn-primary w-100 mt-2 shadow-sm"
                       href="/book/@book.Slug">
                        مشاهده و دانلود
                    </a>
                </div>
            </div>
        </div>
    }
</div>
