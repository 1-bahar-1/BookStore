@model IEnumerable<BookStore.Models.Book>

@{
    ViewData["Title"] = "همه کتاب‌ها";
}

<div class="hero-section text-center" style="padding: 2.5rem 0;">
    <h2>📚 کتاب‌های ما</h2>
    <p class="text-white-50">لیست کامل کتاب‌های موجود در فروشگاه</p>
    <form method="get" asp-action="Index" class="search-box mt-3">
        <div class="input-group input-group-lg">
            <input class="form-control" name="q" value="@Context.Request.Query["q"]" placeholder="جستجو در عنوان کتاب..." />
            <button class="btn btn-light text-primary" type="submit"><i class="bi bi-search"></i></button>
        </div>
    </form>
</div>

<div class="row g-4">
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <div class="text-muted">
                <i class="bi bi-search fs-1 d-block mb-3"></i>
                <p>هیچ کتابی یافت نشد.</p>
            </div>
        </div>
    }

    @foreach (var book in Model)
    {
        <div class="col-lg-3 col-md-4 col-sm-6">
            <div class="card book-card h-100">
                @if (!string.IsNullOrEmpty(book.CoverImagePath))
                {
                    <img src="@book.CoverImagePath" alt="@book.Title" class="card-img-top" style="height: 200px; object-fit: cover;" />
                }
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                        <i class="bi bi-book text-muted" style="font-size: 3rem;"></i>
                    </div>
                }
                <div class="card-body">
                    <h6 class="card-title">@book.Title</h6>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge bg-light text-dark border">@book.Category?.Name</span>
                        <span class="badge bg-light text-dark border">@book.PageCount صفحه</span>
                        @if (book.IsFree)
                        {
                            <span class="badge badge-free">رایگان</span>
                        }
                    </div>
                    <a class="btn btn-primary w-100 mt-auto" href="/books/@book.Slug">
                        مشاهده <i class="bi bi-arrow-left"></i>
                    </a>
                </div>
            </div>
        </div>
    }
</div>
