@model List<BookStore.Models.Book>

@{
    ViewData["Title"] = "Books";
}

<h2 class="mb-4 fw-bold">📚 لیست کتاب‌ها</h2>

<div class="row">

    @foreach (var book in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm book-card">

                <!-- Image -->
                <img src="/images/book.png" class="card-img-top" />

                <!-- Body -->
                <div class="card-body d-flex flex-column">

                    <h5 class="fw-bold">@book.Title</h5>

                    <p class="text-muted mb-1">
                        دسته: @book.Category?.Name
                    </p>

                    <p class="text-muted small">
                        صفحات: @book.PageCount
                    </p>

                    <!-- Spacer -->
                    <div class="mt-auto">

                        <a href="/book/@book.Slug" class="btn btn-outline-primary w-100">
                            مشاهده جزئیات
                        </a>

                    </div>
                </div>

            </div>
        </div>
    }

</div>