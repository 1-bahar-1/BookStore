@{
    ViewData["Title"] = "ثبت نام";
}

<div class="row justify-content-center align-items-center min-vh-100" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-lg border-0" style="border-radius: 20px;">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <div class="display-1 mb-2">📝</div>
                    <h3 class="fw-bold">ثبت نام</h3>
                    <p class="text-muted">حساب کاربری جدید بسازید</p>
                </div>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">ایمیل</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-envelope"></i>
                            </span>
                            <input name="email" type="email" class="form-control border-start-0" placeholder="example@email.com" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">رمز عبور</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-lock"></i>
                            </span>
                            <input name="password" type="password" class="form-control border-start-0" placeholder="رمز عبور" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">تکرار رمز عبور</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-lock-fill"></i>
                            </span>
                            <input name="confirmPassword" type="password" class="form-control border-start-0" placeholder="تکرار رمز عبور" required />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 mb-3">
                        <i class="bi bi-person-plus"></i> ثبت نام
                    </button>

                    <div class="text-center">
                        <span class="text-muted">قبلا ثبت نام کردی؟</span>
                        <a asp-action="Login" class="text-decoration-none fw-bold">وارد شو</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
