@{
    ViewData["Title"] = "ثبت نام";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow-sm p-4">
            <h3 class="text-center mb-4">📝 ثبت نام</h3>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label">ایمیل</label>
                    <input name="email" type="email" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">رمز عبور</label>
                    <input name="password" type="password" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">تکرار رمز عبور</label>
                    <input name="confirmPassword" type="password" class="form-control" required />
                </div>

                <button type="submit" class="btn btn-success w-100">ثبت نام</button>
            </form>

            <div class="text-center mt-3">
                <a asp-action="Login">قبلا ثبت نام کردی؟</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
