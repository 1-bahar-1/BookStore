@{
    ViewData["Title"] = "ورود";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow-sm p-4">
            <h3 class="text-center mb-4">🔐 ورود</h3>

            <form asp-action="Login" method="post">
                @* نمایش خطاهای اعتبار سنجی عمومی *@
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label">ایمیل</label>
                    <input name="email" type="email" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">رمز عبور</label>
                    <input name="password" type="password" class="form-control" required />
                </div>

                <div class="mb-3 form-check">
                    <input name="rememberMe" type="checkbox" value="true" class="form-check-input" id="rememberMe" />
                    <label class="form-check-label" for="rememberMe">مرا به خاطر بسپار</label>
                </div>

                <button type="submit" class="btn btn-primary w-100">ورود</button>
            </form>

            <div class="text-center mt-3">
                <a asp-action="Register">ثبت نام نکردی؟</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
