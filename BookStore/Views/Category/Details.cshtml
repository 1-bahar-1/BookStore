@model IEnumerable<BookStore.Models.Book>

@{
    ViewData["Title"] = ViewBag.CategoryName;
}

<div class="hero-section text-center" style="padding: 2.5rem 0;">
    <h2>📂 کتاب‌های دسته‌بندی @ViewBag.CategoryName</h2>
    <p class="text-white-50">تمامی کتاب‌های این دسته‌بندی</p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-light text-primary mt-2">
        <i class="bi bi-arrow-right"></i> بازگشت به خانه
    </a>
</div>

<div class="row g-4">
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <div class="text-muted">
                <i class="bi bi-folder fs-1 d-block mb-3"></i>
                <p>کتابی در این دسته‌بندی یافت نشد.</p>
            </div>
        </div>
    }

    @foreach (var book in Model)
    {
        <div class="col-lg-3 col-md-4 col-sm-6">
            <div class="card book-card h-100">
                <div class="card-body">
                    <h6 class="card-title">@book.Title</h6>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @if (book.IsFree)
                        {
                            <span class="badge badge-free">رایگان</span>
                        }
                        else
                        {
                            <span class="badge badge-paid">پولی</span>
                        }
                    </div>
                    <a class="btn btn-primary w-100 mt-auto" href="/books/@book.Slug">
                        مشاهده <i class="bi bi-arrow-left"></i>
                    </a>
                </div>
            </div>
        </div>
    }
</div>
